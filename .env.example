# Postgres DB
POSTGRES_HOST=db
POSTGRES_DB=
PG_POOL_SIZE=30
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST_PORT=5432
POSTGRES_PORT=5432

# S3 Storage
S3_HOST_PORT=9000
S3_API_PORT=9000
S3_ENDPOINT=http://s3:9000
S3_PUBLIC_ENDPOINT=https://example.com
S3_REGION=auto
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# API Server Configuration
API_HOST_PORT=5050
SERVER_ENV=dev # or 'prod'

# JWT Secret
JWT_SECRET=
ACCESS_TOKEN_EXPIRES_IN=30m

# FCM project ID for push notification
FCM_PROJECT_ID=

# Mail Server Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth Client ID for sign in with google
GOOGLE_CLIENT_ID=

# Redis
REDIS_HOST_PORT=6379
REDIS_HOST=redis
REDIS_PORT=6379