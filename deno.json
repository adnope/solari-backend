{
  "tasks": {
    "migrate": "deno run --allow-env --allow-read --allow-net --allow-sys migrations/migrate.ts",
    "dev": "deno run --watch --allow-net --allow-read --allow-env --allow-sys --allow-ffi --allow-write --allow-run src/main.ts"
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1004.0",
    "@aws-sdk/s3-request-presigner": "npm:@aws-sdk/s3-request-presigner@^3.1004.0",
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@hono/hono": "jsr:@hono/hono@^4.12.5",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",
    "argon2": "npm:argon2@^0.44.0",
    "image-size": "npm:image-size@^2.0.2",
    "jsonwebtoken": "npm:jsonwebtoken@^9.0.3"
  },
  "compilerOptions": {
    "checkJs": true
  }
}