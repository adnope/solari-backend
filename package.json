{
  "name": "solari-backend",
  "main": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts",
    "migrate": "bun run migrations/migrate.ts",
    "fmt": "prettier --write \"src/**/*.ts\" \"migrations/migrate.ts\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "@types/jsonwebtoken": "^9.0.10",
    "prettier": "^3.8.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "google-auth-library": "^10.6.1",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5"
  }
}
