{
  "name": "solari-backend-bun",
  "main": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --hot src/main.ts",
    "migrate": "bun run migrations/migrate.ts",
    "fmt": "prettier --write \"src/**/*.ts\" \"migrations/migrate.ts\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "prettier": "^3.8.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "google-auth-library": "^10.6.1",
    "hono": "^4.12.5",
    "image-size": "^2.0.2",
    "jsonwebtoken": "^9.0.3",
    "sharp": "^0.34.5"
  }
}
